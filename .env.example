# ============================================================================
# GOLF CHARITY PLATFORM - ENVIRONMENT CONFIGURATION EXAMPLE
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# ============================================================================

# ============================================================================
# APPLICATION CONFIG
# ============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=BirdieFund
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# DATABASE - MongoDB ATLAS
# ============================================================================
# Sign up at https://www.mongodb.com/cloud/atlas
# Create a cluster and get your connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?appName=Cluster0
MONGODB_DB_NAME=birdiefund

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Generate a random 32+ character string for JWT signing
# Run: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-in-production

# Default admin account credentials (change these!)
ADMIN_EMAIL=xxxxxxxxxx
ADMIN_PASSWORD=xxxxxxxxxx

# ============================================================================
# STRIPE PAYMENT INTEGRATION
# ============================================================================
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Product IDs (create these in Stripe Dashboard)
STRIPE_MONTHLY_PRICE_ID=price_test_monthly_here
STRIPE_YEARLY_PRICE_ID=price_test_yearly_here

# ============================================================================
# EMAIL NOTIFICATIONS (Optional - leave commented for development)
# ============================================================================
# For development, email logs are printed to console
# For production, configure with your email provider

# Gmail Setup (SMTP):
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an "App Password" (not your regular password)
# 3. Use the 16-character app password below

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password-16chars
# SMTP_FROM_EMAIL=noreply@birdiefund.com

# Alternative (SendGrid):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxx
# SMTP_FROM_EMAIL=noreply@birdiefund.com

# ============================================================================
# FEATURE FLAGS (Coming Soon)
# ============================================================================

# FEATURE_CAMPAIGNS_ENABLED=false
# FEATURE_MOBILE_SDK_ENABLED=false
# FEATURE_MULTI_ORGANIZATION_ENABLED=false

# ============================================================================
# DEPLOYMENT & INFRASTRUCTURE
# ============================================================================

# Production URLs
# NEXT_PUBLIC_SITE_URL=https://birdiefund.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# API Rate Limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. MONGODB_URI
#    - Create MongoDB Atlas account at https://www.mongodb.com/cloud/atlas
#    - Create a cluster and database user
#    - Click "Connect" and copy connection string
#    - Replace: username, password, cluster name, database name
#
# 2. JWT_SECRET
#    - Generate: openssl rand -base64 32
#    - Keep secret and change for production
#
# 3. STRIPE Setup
#    - Sign up at https://stripe.com
#    - Create monthly and yearly prices
#    - Copy Price IDs (starts with "price_")
#
# 4. EMAIL (Optional for development)
#    - Development: Leave commented (logs to console)
#    - Production: Use Gmail App Password or SendGrid API Key
#
# 5. Security Checklist
#    ✓ Never commit .env.local to Git
#    ✓ Keep JWT_SECRET private
#    ✓ Use test credentials for development
#    ✓ Use production credentials only in production
#    ✓ Rotate API keys regularly
#    ✓ Enable 2FA on all service accounts
#
# ============================================================================
